# Copy to .env and fill in values before running docker-compose

# PostgreSQL password
DB_PASSWORD=changeme

# JWT signing secret — use a long random string (min 32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-string-before-running

# EduPage public hash (currently always 00000000 for public timetable)
EDUPAGE_GSH=00000000

# School year used to discover the current timetable edition (e.g. 2025 → 2025-26)
EDUPAGE_EDITION_YEAR=2025

# Frontend public API URL (used by Next.js at build time for SSR)
NEXT_PUBLIC_API_URL=http://localhost:8080
