# Copy to .env and fill in values before running docker-compose

# PostgreSQL password
DB_PASSWORD=changeme

# JWT signing secret — use a long random string (min 32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-string-before-running

# Origins allowed to call the API from a browser (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Admin bootstrap: on startup the user with this email is promoted to ADMIN.
# If the account doesn't exist yet and a password is given, it is created.
APP_ADMIN_EMAIL=
APP_ADMIN_PASSWORD=

# EduPage public hash (currently always 00000000 for public timetable)
EDUPAGE_GSH=00000000

# School year used to discover the current timetable edition (e.g. 2025 → 2025-26)
EDUPAGE_EDITION_YEAR=2025

# Production reverse proxy (docker-compose.prod.yml) — your domain and the email
# Let's Encrypt uses for certificate notices. Leave blank for local dev.
DOMAIN=
TLS_EMAIL=
